# Copy to .env and edit. Never commit .env.

# Tell `docker compose` to always merge the dev overlay on top of the base
# file, so commands like `docker compose run --rm n8n-import` work without
# repeating `-f docker-compose.yml -f docker-compose.dev.yml` every time.
# The `n8n-import` sidecar and the `../awp-agents` mount only exist in the
# overlay; without this var, `docker compose run --rm n8n-import` errors
# with "no such service: n8n-import".
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# Local time zone, used by n8n cron triggers.
TZ=Europe/Moscow

# 32+ char random string used to encrypt n8n credentials at rest.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-to-32-plus-random-chars

# Host/port that the n8n editor is exposed on.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Optional: external port for echo-mcp (M0 only).
ECHO_MCP_PORT=8800

# Atlassian workspace domain — the host portion only, e.g. mycompany.atlassian.net.
# Used for human-facing URLs (browse links in comments, etc.). Service account
# tokens cannot authenticate against this domain — they go through
# api.atlassian.com/ex/jira/{JIRA_CLOUD_ID} instead (see JIRA_CLOUD_ID below).
JIRA_DOMAIN=your-workspace.atlassian.net

# Atlassian cloudId for JIRA_DOMAIN. Required because Atlassian service account
# API tokens are *scoped* tokens and only work against the gateway URL pattern
# https://api.atlassian.com/ex/jira/<cloudId>/rest/api/..., not against the
# <workspace>.atlassian.net domain. See:
#   https://support.atlassian.com/atlassian-cloud/kb/401-unauthorized-error-when-service-account-accesses-jira-or-confluence-api/
#
# Look it up once with:
#   curl -s https://<workspace>.atlassian.net/_edge/tenant_info
# Paste the "cloudId" field below. It's stable per workspace.
JIRA_CLOUD_ID=00000000-0000-0000-0000-000000000000

# n8n REST API key. Used by the workflow-import sidecar to *activate* imported
# workflows (registering webhook listeners in the running n8n process). Left
# empty on first boot; populated after the one-time UI step below.
#
# One-time setup after the first `docker compose up`:
#   1. http://localhost:5678 → Settings → n8n API → Create an API key.
#   2. Paste it here.
#   3. docker compose up   (or  docker compose run --rm n8n-import)
#
# Until this is set, workflows are still imported, but you have to toggle
# "Active" manually in the UI.
N8N_API_KEY=
