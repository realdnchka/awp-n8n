# Copy to .env and edit. Never commit .env.

# Local time zone, used by n8n cron triggers.
TZ=Europe/Moscow

# 32+ char random string used to encrypt n8n credentials at rest.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-to-32-plus-random-chars

# Host/port that the n8n editor is exposed on.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Optional: external port for echo-mcp (M0 only).
ECHO_MCP_PORT=8800

# n8n REST API key. Used by the workflow-import sidecar to *activate* imported
# workflows (registering webhook listeners in the running n8n process). Left
# empty on first boot; populated after the one-time UI step below.
#
# One-time setup after the first `docker compose up`:
#   1. http://localhost:5678 → Settings → n8n API → Create an API key.
#   2. Paste it here.
#   3. docker compose up   (or  docker compose run --rm n8n-import)
#
# Until this is set, workflows are still imported, but you have to toggle
# "Active" manually in the UI.
N8N_API_KEY=
